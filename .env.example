# Cloudflare R2 — Storage credentials (server-only, jamais exposé au client)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=assets

# URL publique du bucket R2 (Public Access activé), sans slash final
# Ex : https://assets.motus-pocus.com
NEXT_PUBLIC_R2_PUBLIC_URL=

# Auth admin — protège /admin/* et les routes API d'écriture
# ADMIN_PASSWORD : mot de passe partagé que tu et tes co-admins utilisez pour vous connecter
# ADMIN_SESSION_SECRET : secret aléatoire (>= 32 caractères) pour signer les cookies de session
# Génère les deux avec :
#   node -e "const c=require('crypto'); console.log(c.randomBytes(16).toString('base64url')); console.log(c.randomBytes(32).toString('base64url'))"
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
